{
  "name": "cicd-demo-app",
  "version": "1.0.0",
  "description": "Production-grade Node.js app for CI/CD demonstration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit",
    "test:ci": "jest --coverage --forceExit --ci --reporters=default --reporters=jest-junit",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["*.js", "!jest.config.js"],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}
